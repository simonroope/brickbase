# RPC endpoints
ETH_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_KEY

# Deployer key (DO NOT COMMIT REAL KEYS)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional explorer API keys
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Core protocol addresses (per network; also mirrored in deploy/<network>.json)
USDC_ADDRESS=
CHAINLINK_ETH_USD_FEED=
CHAINLINK_GBP_USD_FEED=
CHAINLINK_GOLD_USD_FEED=
CHAINLINK_FTSE100_FEED=

# Protocol fee configuration (example if needed later)
FEE_RECIPIENT=
MANAGEMENT_FEE_BPS=
PERFORMANCE_FEE_BPS=

# Verification helpers for AssetVault or AssetShares (used by scripts/verify.ts)
VERIFY_CONTRACT_ADDRESS=
VERIFY_CONSTRUCTOR_ARGS=[]  # JSON array, e.g. [\"0xAdminAddress\",\"0xAssetSharesAddress\"]

