{
  "name": "mcp-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mcp-server/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc",
        "cwd": "apps/mcp-server"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node src/index.ts",
        "cwd": "apps/mcp-server"
      }
    }
  },
  "implicitDependencies": ["abi", "shared-config"],
  "tags": ["scope:mcp"]
}
