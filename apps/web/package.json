{
  "name": "brickbase-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:for-test": "id=$(cat .next/dev/lock 2>/dev/null); rm -f .next/dev/lock 2>/dev/null; [ -n \"$id\" ] && echo \"Locks deleted: $id\"; next dev --webpack",
    "dev:locks": "id=$(cat .next/dev/lock 2>/dev/null); rm -f .next/dev/lock 2>/dev/null; if [ -n \"$id\" ]; then echo \"Locks deleted: $id\"; else echo \"No locks to delete\"; fi",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "test": "jest",
    "test:server": "start-server-and-test 'dev:for-test' http://localhost:3000",
    "test:integration": "start-server-and-test 'dev:for-test' http://localhost:3000 \"TS_NODE_COMPILER_OPTIONS='{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}' cucumber-js -p integration\"",
    "test:e2e": "start-server-and-test 'dev:for-test' http://localhost:3000 \"TS_NODE_COMPILER_OPTIONS='{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}' cucumber-js -p e2e\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-query": "^5.90.21",
    "zod": "^4.3.6",
    "@web3modal/wagmi": "^5.1.11",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.46.2",
    "wagmi": "^3.5.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
